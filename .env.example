# Backend
PORT=3000
DATABASE_URL=postgresql://squeaky:squeaky@localhost:5432/squeaky_wheel

# Supabase Auth — use JWKS (recommended) or JWT secret
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-jwt-secret

# Local dev without Supabase (do not use in production)
AUTH_DEV_BYPASS=true
AUTH_DEV_USER_ID=00000000-0000-4000-8000-000000000001
AUTH_DEV_USER_EMAIL=dev@localhost

# LLM — mock provider for local dev/tests; set anthropic:model + API key for live calls
LLM_PROVIDER=mock
# LLM_PROVIDER=anthropic:claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...

# Calendar — mock provider for local dev/tests; set google + OAuth creds for live writes
CALENDAR_PROVIDER=mock
# CALENDAR_PROVIDER=google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/calendar/oauth/callback
# API_BASE_URL=http://localhost:3000
