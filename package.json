{
  "name": "squeaky-wheel",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev:backend": "pnpm --filter @squeaky-wheel/backend dev",
    "dev:mobile": "pnpm --filter @squeaky-wheel/mobile start",
    "db:generate": "pnpm --filter @squeaky-wheel/backend db:generate",
    "db:migrate": "pnpm --filter @squeaky-wheel/backend db:migrate",
    "db:studio": "pnpm --filter @squeaky-wheel/backend db:studio",
    "test:phase": "node scripts/test-phases.mjs",
    "test:phase:1": "node scripts/test-phases.mjs 1",
    "test:phase:2": "node scripts/test-phases.mjs 2",
    "test:phase:3": "node scripts/test-phases.mjs 3",
    "test:phase:4": "node scripts/test-phases.mjs 4",
    "test:phase:5": "node scripts/test-phases.mjs 5",
    "test:phase:6": "node scripts/test-phases.mjs 6",
    "test:anti-stall": "pnpm --filter @squeaky-wheel/backend test",
    "monitor:orchestrator": "node scripts/monitor-orchestrator.mjs",
    "test:phase:list": "node scripts/test-phases.mjs --list"
  },
  "engines": {
    "node": ">=20"
  }
}
